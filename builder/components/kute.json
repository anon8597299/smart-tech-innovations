{
  "id": "kute",
  "name": "KUTE.js",
  "category": "svg-morphing",
  "license": "MIT",
  "repo": "https://github.com/thednp/kute.js",
  "description": "SVG path morphing engine — animates blob/organic shapes from one SVG path to another. Also handles CSS filter animation, colour interpolation and border-radius morphing.",
  "use_cases": ["morphing blob hero backgrounds", "animated logo shape transitions", "organic shape reveals", "SVG icon morphing", "animated wave dividers"],
  "head": "<script src=\"https://cdn.jsdelivr.net/npm/kute.js@2.2.4/dist/kute.min.js\"></script>",
  "body": "<script>\n(function() {\n  if (typeof KUTE === 'undefined') return;\n  // Morphing blob — requires two SVG path elements\n  var blob1 = document.querySelector('#blob-path-1');\n  var blob2 = document.querySelector('#blob-path-2');\n  if (!blob1 || !blob2) return;\n\n  var tween1 = KUTE.to(blob1, { path: blob2 }, { duration: 2000, easing: 'easingCubicInOut', repeat: 999, yoyo: true });\n  tween1.start();\n\n  // Example blob paths to add to your HTML:\n  // <svg viewBox=\"0 0 200 200\" xmlns=\"http://www.w3.org/2000/svg\" style=\"position:absolute;opacity:0.15\">\n  //   <path id=\"blob-path-1\" d=\"M47.5,-57C60.7,-46.8,69.7,-30.5,71.8,-13.5C73.9,3.6,69,21.4,59.4,36.1C49.8,50.8,35.5,62.4,18.8,67.5C2.1,72.5,-17,71.1,-32.8,63.3C-48.6,55.5,-61.2,41.4,-67.3,24.8C-73.4,8.1,-73,-11,-65.5,-26.8C-57.9,-42.7,-43.2,-55.3,-27.8,-64.8C-12.3,-74.3,3.8,-80.6,18.1,-76.5C32.4,-72.3,34.4,-67.3,47.5,-57Z\" fill=\"#5b4dff\"/>\n  //   <path id=\"blob-path-2\" d=\"M38.9,-49.5C51.8,-40.4,64.5,-30.3,68.7,-17.3C73,-4.3,68.7,11.7,60.7,25.5C52.8,39.3,41.2,50.9,27.2,57.3C13.2,63.7,-3.1,64.8,-19.6,61.1C-36.1,57.4,-52.8,48.8,-61.3,35.8C-69.8,22.8,-70.2,5.3,-66,-11.3C-61.7,-27.9,-52.8,-43.6,-40.2,-52.8C-27.6,-62,-13.8,-64.8,-0.1,-64.7C13.6,-64.5,26,-58.6,38.9,-49.5Z\" fill=\"#5b4dff\"/>\n  // </svg>\n})();\n</script>"
}
