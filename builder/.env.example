# Copy this file to .env and fill in your GitHub Personal Access Token.
# The token needs "repo" scope (read + write to the smart-tech-innovations repo).
#
# Create one at: https://github.com/settings/tokens
# Select scopes: repo (full control of private repositories)

GITHUB_PAT=ghp_your_token_here

# Required for blog_generator.py (AI-generated blog posts for Premium customers)
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Agent System ──────────────────────────────────────────────────────────────

# Gmail SMTP — for agent email notifications to hello@improveyoursite.com
# Use a Google App Password (not your main password):
# myaccount.google.com → Security → App passwords
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASS=xxxx-xxxx-xxxx-xxxx

# Instagram Graph API — needed for Social agent insights
# Obtain via: Meta Developer App → instagram_basic + read_insights permissions
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Google Ads API — needed for Ads agent performance data
# Obtain: https://developers.google.com/google-ads/api/docs/get-started/oauth-cloud-project
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
